# Runtime mode
NODE_ENV=development

# Alpha Radar API
PORT=4000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# Kiwoom OpenAPI (fill later)
KIWOOM_MODE=mock
# Generic fallback keys (used if mode-specific keys below are empty)
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_ACCESS_TOKEN=
KIWOOM_REFRESH_TOKEN=
KIWOOM_REST_BASE_URL=
KIWOOM_WS_URL=

# Optional mode-specific overrides (preferred when you use both paper/live)
KIWOOM_PAPER_APP_KEY=
KIWOOM_PAPER_APP_SECRET=
KIWOOM_PAPER_ACCESS_TOKEN=
KIWOOM_PAPER_REFRESH_TOKEN=
KIWOOM_PAPER_REST_BASE_URL=
KIWOOM_PAPER_WS_URL=

KIWOOM_LIVE_APP_KEY=
KIWOOM_LIVE_APP_SECRET=
KIWOOM_LIVE_ACCESS_TOKEN=
KIWOOM_LIVE_REFRESH_TOKEN=
KIWOOM_LIVE_REST_BASE_URL=
KIWOOM_LIVE_WS_URL=
